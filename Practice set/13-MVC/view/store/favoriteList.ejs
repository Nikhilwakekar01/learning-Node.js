<%- include('../partials/head')%>
    
  </head>
  <body class="bg-[#FFFFFC] flex-col justify-items-center ">
    <%- include('../partials/nav')%>
   
    <header class="flex justify-center w-fit p-6 h-fit bg-[#00272b]   mt-10 drop-shadow-xl border border-gray-500 rounded-lg ">
      
      <h1 class="text-4xl text-white font-mono font-semibold  " >your favorites</h1>
    </header>
    <main class="max-w-3xl mx-auto mt-10 p-6 bg-gray-100 rounded-xl shadow-lg">
  
  <h1 class="text-3xl font-bold text-gray-800 mb-6 border-b-2 border-blue-500 pb-2">
    🏠 Here is your favaorite list
  </h1>

  <ul class="space-y-4">
    <% houseList.forEach(house => { %>
      <li class="overflow-hidden rounded-2xl border border-gray-200 bg-white shadow-md transition duration-300 hover:shadow-xl">
        <div class="flex flex-col md:flex-row">
          <img
            src="<%= house.photos %>"
            alt="<%= house.home %>"
            class="h-48 w-full object-cover md:w-52"
          />

          <div class="flex-1 p-5">
            <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
              <div>
                <h2 class="text-xl font-semibold text-gray-800"><%= house.home %></h2>
                <p class="text-sm text-gray-500">Contact: <%= house.contact %></p>
              </div>

              <span class="inline-block rounded-full bg-emerald-100 px-3 py-1 text-sm font-medium text-emerald-700">
                ₹<%= house.rent %>/month
              </span>
            </div>

            <p class="mt-3 text-gray-600">
              <span class="font-medium text-gray-700">Address:</span> <%= house.address %>
            </p>
            
            <div class="mt-4 flex flex-wrap gap-2 ">
              <button class="bg-blue-500 hover:bg-blue-600 text-white font-bold  px-4 rounded">
                Book
              </button>
              <span class="rounded-full bg-blue-50 px-3  text-sm text-blue-700">
                Available
              </span>
              <span class="rounded-full bg-gray-100 px-3  text-sm text-gray-700">
                Verified Home
              </span>
            </div>
          </div>
        </div>
      </li>
    <% }) %>
  </ul>

</main>
  </body>
</html>
