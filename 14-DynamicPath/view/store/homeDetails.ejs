<%- include('../partials/head')%>
    
  </head>
  <body class="bg-[#FFFFFC] flex-col justify-items-center ">
    <%- include('../partials/nav')%>
   
    <header class="flex justify-center w-fit p-6 h-fit bg-[#00272b]   mt-10 drop-shadow-xl border border-gray-500 rounded-lg ">
      
      <h1 class="text-4xl text-white font-mono font-semibold  " >this is your home details</h1>
    </header>
    <main class="max-w-3xl mx-auto mt-10 p-6 bg-gray-100 rounded-xl shadow-lg">
             <div class="flex flex-col md:flex-row">
          <img
            src="<%= home.photos %>"
            alt="<%= home.home %>"
            class="h-48 w-full object-cover md:w-52"
          />

          <div class="flex-1 p-5">
            <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
              <div>
                <h2 class="text-xl font-semibold text-gray-800"><%= home.home %></h2>
                <p class="text-sm text-gray-500">Contact: <%= home.contact %></p>
              </div>

              <span class="inline-block rounded-full bg-emerald-100 px-3 py-1 text-sm font-medium text-emerald-700">
                ₹<%= home.rent %>/month
              </span>
            </div>

            <p class="mt-3 text-gray-600">
              <span class="font-medium text-gray-700">Address:</span> <%= home.address %>
            </p>
            
            <div class="mt-4 flex flex-wrap gap-2 ">
              <button class="bg-blue-500 hover:bg-blue-600 text-white font-bold  px-4 rounded">
                Book
              </button>
              
              <%- include('../partials/favourite',{home:home})%>
            </div>
          </div>
        </div>

    </main>
  </body>
</html>
